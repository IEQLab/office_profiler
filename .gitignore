# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# RStudio files
.Rproj.user/

# Knitr / R Markdown caches and temp files
*_cache/
/cache/
*.utf8.md
*.knit.md

# R environment variables — never commit
.Renviron
.env
.env.*

# macOS
.DS_Store

# Raw and processed CBE data — proprietary, not redistributable
data/raw/*
!data/raw/README.md
data/processed/*
!data/processed/.gitkeep
data/interim/*

# Targets pipeline cache
_targets/

# renv library (lockfile + activate.R + settings.json are tracked)
renv/library/
renv/staging/
renv/local/
renv/cellar/

# Generated figures regenerated by the pipeline
reports/figures/*.png
reports/figures/*.pdf
!reports/figures/.gitkeep
!reports/figures/pipeline_architecture.R

# Knitted reports
*.html

# Compiled LaTeX output
*.log
paper/*.pdf
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
paper/*.cut

# OAuth2 token
.httr-oauth
